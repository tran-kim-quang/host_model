# Default Models
MODEL_LLM=gemma4:26b
MODEL_EMBEDDING=qwen3-embedding:8b
EMBEDDING_DIM=4096

# Ollama Base URL (change localhost to 0.0.0.0 for network access)
BASE_URL=http://localhost:11434

# API Server Configuration
API_HOST=0.0.0.0
API_PORT=8000

# Access Control (recommended for LAN/WAN)
# Set SECURITY_ENABLED=true to enforce API key and allowlist checks.
SECURITY_ENABLED=true

# Comma-separated API keys used in X-API-Key header.
# Change this value before exposing the API.
API_KEYS=change-this-to-a-strong-key

# Optional: only allow requests from these client hostnames (reverse DNS).
# Example: ALLOWED_CLIENT_HOSTNAMES=laptop-a,worker-01
ALLOWED_CLIENT_HOSTNAMES=desktop,server

# Optional: only allow requests from these client IPs.
# Example: ALLOWED_CLIENT_IPS=192.168.1.10,192.168.1.11
ALLOWED_CLIENT_IPS=

# Hostname-based Model Mapping (hostname:model_name)
# Example: HOST1_MODEL_LLM=gemma4:26b
# If hostname matches HOST1, use gemma4:26b instead of default
HOST1_NAME=desktop
HOST1_MODEL_LLM=gemma4:26b

HOST2_NAME=server
HOST2_MODEL_LLM=neural-chat:7b

# Enable debug mode
DEBUG=false
